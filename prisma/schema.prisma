// Permissioned Task Manager — data model
// See plan: per-user tab + row visibility, custom fields per tab, WhatsApp ingest.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  member
}

enum UserStatus {
  pending
  approved
}

enum VisibilityMode {
  ALL_ROWS
  TAGGED_ONLY
}

enum FieldType {
  text
  select
  checkbox
  person
  date
}

enum TaskSource {
  manual
  whatsapp
}

// ---- Auth.js (NextAuth) models + app fields ----
model User {
  id            String     @id @default(cuid())
  name          String?
  nickname      String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          Role       @default(member)
  status        UserStatus @default(pending)
  createdAt     DateTime   @default(now())

  accounts         Account[]
  sessions         Session[]
  memberships      TabMembership[]
  assignments      TaskAssignee[]
  fieldPermissions FieldPermission[]
  groupsCreated    Group[]           @relation("GroupCreator")
  groupMemberships GroupMembership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Domain models ----
model Tab {
  id             String         @id @default(cuid())
  name           String
  order          Int            @default(0)
  visibilityMode VisibilityMode @default(TAGGED_ONLY)
  createdAt      DateTime       @default(now())

  memberships TabMembership[]
  fields      FieldDef[]
  tasks       Task[]
}

model TabMembership {
  id     String @id @default(cuid())
  userId String
  tabId  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tab    Tab    @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@unique([userId, tabId])
  @@index([tabId])
}

model FieldDef {
  id      String    @id @default(cuid())
  tabId   String
  key     String // stable key used inside Task.values JSON
  label   String
  type    FieldType
  options Json? // for select: array of strings
  order   Int       @default(0)
  tab         Tab             @relation(fields: [tabId], references: [id], onDelete: Cascade)
  permissions FieldPermission[]

  @@unique([tabId, key])
  @@index([tabId])
}

model Task {
  id        String     @id @default(cuid())
  tabId     String
  position  Int        @default(0)
  source    TaskSource @default(manual)
  values    Json       @default("{}") // keyed by FieldDef.key
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tab       Tab        @relation(fields: [tabId], references: [id], onDelete: Cascade)
  assignees TaskAssignee[]
  groupTags TaskGroupAssignee[]

  @@index([tabId])
}

model TaskAssignee {
  id     String @id @default(cuid())
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId])
}

model FieldPermission {
  id      String   @id @default(cuid())
  userId  String
  fieldId String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  field   FieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([userId, fieldId])
  @@index([userId])
  @@index([fieldId])
}

// ---- Groups: taggable sets of members with live membership ----
model Group {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime @default(now())

  createdBy User                @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members   GroupMembership[]
  taskTags  TaskGroupAssignee[]

  @@index([createdById])
}

model GroupMembership {
  id      String @id @default(cuid())
  groupId String
  userId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

// A live group tag on a task: whoever is in the group right now is "tagged".
model TaskGroupAssignee {
  id      String @id @default(cuid())
  taskId  String
  groupId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([taskId, groupId])
  @@index([groupId])
  @@index([taskId])
}

model WhatsAppLog {
  id         String   @id @default(cuid())
  rawPayload Json
  parsed     Json?
  status     String // ok | error
  error      String?
  createdAt  DateTime @default(now())
}
