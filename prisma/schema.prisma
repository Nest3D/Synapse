// Permissioned Task Manager — data model
// Access is column-scoped: each FieldDef carries an access rule (ALL / INCLUDE /
// EXCLUDE over approved users). A user can see a brood (Tab) if at least one of
// its columns is visible to them; all rows in an accessible brood are visible.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  member
}

enum UserStatus {
  pending
  approved
}

enum FieldType {
  text
  select
  checkbox
  person
  date
}

enum TaskSource {
  manual
  whatsapp
}

enum TaskScope {
  BROOD // belongs to a brood; visibility via column access (+ tags / creator)
  EVERYONE // every approved member can see it ("All Tasks")
  PRIVATE // only the creator (+ tagged people) can see it ("My Tasks")
}

enum FieldAccessMode {
  ALL // every approved user
  INCLUDE // only the listed users
  EXCLUDE // every approved user except the listed users
}

// ---- Auth.js (NextAuth) models + app fields ----
model User {
  id            String     @id @default(cuid())
  name          String?
  nickname      String?
  phone         String?    @unique // WhatsApp number (digits only), admin-entered
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          Role       @default(member)
  status        UserStatus @default(pending)
  createdAt     DateTime   @default(now())

  accounts      Account[]
  sessions      Session[]
  fieldAccess   FieldAccessUser[]
  assignments   TaskAssignee[]
  createdTasks  Task[]            @relation("TaskCreator")
  notifications  Notification[]
  ownedBroods    Tab[]             @relation("BroodOwner")
  whatsappAliases WhatsAppAlias[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Domain models ----
model Tab {
  id         String    @id @default(cuid())
  name       String
  order      Int       @default(0)
  ownerId    String? // null = shared brood (admin); set = personal brood, owner-only
  archivedAt DateTime? // set when the brood is archived ("deleted")
  createdAt  DateTime  @default(now())

  owner  User?      @relation("BroodOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  fields FieldDef[]
  tasks  Task[]
  whatsappAliases WhatsAppAlias[]

  @@index([ownerId])
}

// Admin-defined shortcut: a keyword that maps to a brood or a member, used to
// route inbound WhatsApp tasks. Exactly one of broodId / userId is set.
model WhatsAppAlias {
  id        String   @id @default(cuid())
  keyword   String   @unique // normalized lowercase
  broodId   String?
  userId    String?
  createdAt DateTime @default(now())

  brood Tab?  @relation(fields: [broodId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([broodId])
  @@index([userId])
}

model FieldDef {
  id         String          @id @default(cuid())
  tabId      String
  key        String // stable key used inside Task.values JSON
  label      String
  type       FieldType
  options    Json? // for select: array of strings
  order      Int             @default(0)
  accessMode FieldAccessMode @default(ALL)

  tab    Tab               @relation(fields: [tabId], references: [id], onDelete: Cascade)
  access FieldAccessUser[]

  @@unique([tabId, key])
  @@index([tabId])
}

model Task {
  id          String     @id @default(cuid())
  tabId       String? // null for brood-less tasks (EVERYONE / PRIVATE)
  scope       TaskScope  @default(BROOD)
  createdById String?
  position    Int        @default(0)
  source      TaskSource @default(manual)
  values      Json       @default("{}") // keyed by FieldDef.key (or description/done when brood-less)
  doneAt      DateTime? // set when marked done; drives the Done page
  deletedAt   DateTime? // soft-deleted; shown in Archive, recoverable
  scheduledDay Int? // weekly board: 0=Sunday .. 6=Saturday; null = unscheduled
  dueAt       DateTime? // deadline (default: created + 24h)
  alertAt     DateTime? // when to send the "due soon" reminder
  dueSoonAlertedAt DateTime? // set once the reminder email is sent
  overdueAlertedAt DateTime? // set once the overdue email is sent
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tab       Tab?           @relation(fields: [tabId], references: [id], onDelete: Cascade)
  creator   User?          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignees TaskAssignee[]

  @@index([tabId])
  @@index([scope])
  @@index([createdById])
  @@index([dueAt])
  @@index([deletedAt])
}

// Tagged people: extra visibility + notification targets for a task.
model TaskAssignee {
  id     String @id @default(cuid())
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId])
}

// In-app notification delivered to a recipient when a task is pushed to them.
model Notification {
  id        String   @id @default(cuid())
  userId    String // recipient
  actorName String? // who pushed it (denormalized label)
  taskId    String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// The include/exclude user list for a column's access rule. Ignored when the
// column's accessMode is ALL.
model FieldAccessUser {
  id      String @id @default(cuid())
  fieldId String
  userId  String
  field   FieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fieldId, userId])
  @@index([userId])
  @@index([fieldId])
}

model WhatsAppLog {
  id         String   @id @default(cuid())
  rawPayload Json
  parsed     Json?
  status     String // ok | error
  error      String?
  createdAt  DateTime @default(now())
}
